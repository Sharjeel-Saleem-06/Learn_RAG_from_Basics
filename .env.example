# ============================================
# Environment Variables for RAG Chatbot
# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your API keys below
# 3. NEVER commit .env to git (it's in .gitignore)
#
# WHY .env FILES?
# API keys are like passwords. You NEVER hardcode them in your code.
# .env files keep them separate and secure.
# python-dotenv library loads them into your Python code automatically.
# ============================================

# --- Groq API Key (FREE!) ---
# Get yours at: https://console.groq.com/keys
# Groq provides FREE LLM access with very fast inference
# Models available: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=gsk_L3EmrndfKpQWxcOTnAiaWGdyb3FYXtkHtJJ1hN18Dp2GMDjUABNws

# --- OpenAI API Key (PAID, but optional for this project) ---
# Get yours at: https://platform.openai.com/api-keys
# We'll use this for OpenAI embeddings (optional — we have free alternatives)
OPENAI_API_KEY=your_openai_api_key_here

# --- Embedding Model Configuration ---
# Which embedding model to use: "local" (free) or "openai" (paid, better quality)
# Start with "local" — it's free and works great for learning
EMBEDDING_MODEL=local

# --- LLM Configuration ---
# Which LLM provider to use: "groq" (free) or "openai" (paid)
LLM_PROVIDER=groq

# --- ChromaDB Configuration ---
# Where to store vector database files on your computer
CHROMA_PERSIST_DIR=./chroma_db
